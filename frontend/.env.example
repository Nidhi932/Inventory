# Production (Vercel): set VITE_API_URL in the Vercel dashboard — your Render backend URL, e.g.:
# VITE_API_URL=https://inventory-api-xxxx.onrender.com

# Local dev: omit VITE_API_URL — requests go to /api and Vite proxies to the backend (default port 5001).
# If your backend uses a different port, set:
# VITE_DEV_API_PORT=5001
